int* searchRange(int* nums, int numsSize, int target, int* returnSize) {
    int i,j=0,k;
    int* result=(int *)malloc(2*sizeof(int));
    *returnSize=2;
    result[0]=-1;
    result[1]=-1;
    for(i=0;i<numsSize;i++){
        if(nums[i]==target){
            result[0]=i;
            j++;
            break;
        }
    }
    for(k=numsSize-1;k>=0;k--){
        if(nums[k]==target){
            result[1]=k;
            break;
        }
    }
    

    return result;
}
